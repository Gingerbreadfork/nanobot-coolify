# ═══════════════════════════════════════════════════════════════════════════
#  nanobot on Coolify — Environment Variables
#  Set these in Coolify UI → Environment Variables
#  Mark API keys and tokens as "Secret"
# ═══════════════════════════════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────────────────────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# ── Model ────────────────────────────────────────────────────────────────
# Default: anthropic/claude-sonnet-4-20250514
# Budget: minimax/minimax-m2
# See https://openrouter.ai/models for full list
NANOBOT_MODEL=anthropic/claude-sonnet-4-20250514

# ── Web Search (optional) ───────────────────────────────────────────────
# https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# ── Telegram (optional) ─────────────────────────────────────────────────
# 1. Message @BotFather → /newbot → copy the token
# 2. Get your user ID from @userinfobot
# 3. TELEGRAM_ALLOW_FROM is comma-separated for multiple users
TELEGRAM_ENABLED=true
TELEGRAM_TOKEN=123456:ABC-DEF...
TELEGRAM_ALLOW_FROM=123456789

# ── Discord (optional) ──────────────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications
DISCORD_ENABLED=false
DISCORD_TOKEN=
DISCORD_ALLOW_FROM=

# ── WhatsApp (optional) ─────────────────────────────────────────────────
# After deploy: open Coolify terminal → nanobot channels login → scan QR
WHATSAPP_ENABLED=false
WHATSAPP_ALLOW_FROM=
